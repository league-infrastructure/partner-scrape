# Public (non-secret) configuration for the "prod" deployment.
# Source of truth for the assembled .env — edit here, then `dotconfig load prod`.

# Root directory where scraped partner websites are cached (raw HTML +
# response metadata). Kept off the repo volume so the tens-of-GB mirror
# corpus never lands in git or the working tree.
SCRAPE_CACHE_DIR=/Volumes/Cache/stem-ecosystem
