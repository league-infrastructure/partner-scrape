---
// Calendar View — build-time month grid for the Opportunities index page.
//
// Renders the current month plus the next two (~3 months total) as
// pre-rendered, static month blocks. A small client script toggles which
// block is visible (no new routing, no calendar-library dependency).
//
// Each dated opportunity is placed on its `date_start` day (already the
// next-upcoming occurrence for recurring opportunities, per Normalize &
// Dedup's collapse — see sprint 007's Design Rationale). Undated
// opportunities are omitted entirely; they remain List-only.
//
// Every entry carries the same data-* filter attributes OpportunityCard.astro
// gives its cards (data-type, data-age, data-areas, data-cost, data-time,
// data-financial, data-ngss, data-attention, data-title, data-desc) so
// filters.js can keep Calendar in sync with the sidebar via the existing
// data-attribute show/hide convention, without a second filtering mechanism.

interface Opportunity {
  slug: string;
  title: string;
  description: string;
  date_start: string;
  opportunity_type: string;
  age_grade_level: string[];
  areas_of_interest: string[];
  cost_range: string;
  time_of_day: string[];
  specific_attention: string[];
  financial_support: string;
  ngss_aligned: string;
}

interface Props {
  opportunities: Opportunity[];
}

const { opportunities } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, ''); // "" or "/partner-scrape"

const MONTH_NAMES = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];
const WEEKDAY_NAMES = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

function dayKey(d: Date): string {
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

function formatTime(dateStr: string): string {
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return '';
  return d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
}

// Group dated opportunities by their local calendar day.
const byDay = new Map<string, Opportunity[]>();
for (const opp of opportunities) {
  if (!opp.date_start) continue; // undated opportunities never appear here
  const d = new Date(opp.date_start);
  if (isNaN(d.getTime())) continue;
  const key = dayKey(d);
  if (!byDay.has(key)) byDay.set(key, []);
  byDay.get(key)!.push(opp);
}
for (const list of byDay.values()) {
  list.sort((a, b) => new Date(a.date_start).getTime() - new Date(b.date_start).getTime());
}

const now = new Date();
const todayKey = dayKey(now);

// Build 3 month blocks: current month + next 2.
const months = [0, 1, 2].map(offset => {
  const year = now.getFullYear() + Math.floor((now.getMonth() + offset) / 12);
  const month = (now.getMonth() + offset) % 12;
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const startWeekday = new Date(year, month, 1).getDay(); // 0 = Sunday

  const cells: Array<{ day: number; key: string; opportunities: Opportunity[] } | null> = [];
  for (let i = 0; i < startWeekday; i++) cells.push(null);
  for (let day = 1; day <= daysInMonth; day++) {
    const key = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
    cells.push({ day, key, opportunities: byDay.get(key) || [] });
  }
  while (cells.length % 7 !== 0) cells.push(null);

  return { year, month, label: `${MONTH_NAMES[month]} ${year}`, cells };
});
---

<div class="calendar-view">
  <div class="calendar-nav">
    <button type="button" class="calendar-nav-btn" id="calendar-prev" disabled>&larr; Prev</button>
    <span class="calendar-current-label" id="calendar-current-label">{months[0].label}</span>
    <button type="button" class="calendar-nav-btn" id="calendar-next">Next &rarr;</button>
  </div>

  {months.map((m, i) => (
    <div class="calendar-month" data-month-index={i} data-label={m.label} style={i === 0 ? '' : 'display:none;'}>
      <div class="calendar-weekdays">
        {WEEKDAY_NAMES.map(w => <div class="calendar-weekday">{w}</div>)}
      </div>
      <div class="calendar-grid">
        {m.cells.map(cell => cell ? (
          <div class:list={['calendar-day', { today: cell.key === todayKey }]} data-date={cell.key}>
            <span class="calendar-day-number">{cell.day}</span>
            <div class="calendar-day-entries">
              {cell.opportunities.map(opp => (
                <a
                  class="cal-entry"
                  href={`${base}/opportunities/${opp.slug}`}
                  title={opp.title}
                  data-type={opp.opportunity_type}
                  data-age={opp.age_grade_level?.join(',')}
                  data-areas={opp.areas_of_interest?.join(',')}
                  data-cost={opp.cost_range}
                  data-time={opp.time_of_day?.join(',')}
                  data-financial={opp.financial_support}
                  data-ngss={opp.ngss_aligned}
                  data-attention={opp.specific_attention?.join(',')}
                  data-title={opp.title?.toLowerCase()}
                  data-desc={opp.description?.toLowerCase()?.slice(0, 300)}
                >
                  <span class="cal-entry-time">{formatTime(opp.date_start)}</span>
                  <span class="cal-entry-title">{opp.title}</span>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="calendar-day calendar-day-empty" aria-hidden="true"></div>
        ))}
      </div>
    </div>
  ))}
</div>

<script>
  // Prev/Next navigation across the 3 pre-rendered month blocks. No
  // navigation past this window (sprint 007 Open Question 4 — an
  // accepted limitation, not a bug).
  const monthBlocks = Array.from(document.querySelectorAll<HTMLElement>('.calendar-month'));
  const prevBtn = document.getElementById('calendar-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('calendar-next') as HTMLButtonElement | null;
  const label = document.getElementById('calendar-current-label');
  let current = 0;

  function render() {
    monthBlocks.forEach((block, i) => {
      block.style.display = i === current ? '' : 'none';
    });
    if (label) label.textContent = monthBlocks[current]?.dataset.label || '';
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current === monthBlocks.length - 1;
  }

  prevBtn?.addEventListener('click', () => {
    if (current > 0) {
      current--;
      render();
    }
  });
  nextBtn?.addEventListener('click', () => {
    if (current < monthBlocks.length - 1) {
      current++;
      render();
    }
  });

  render();
</script>
